"use client";

import { useEffect, useMemo, useRef, useState } from "react";
import { ConversationThread, ConversationSetupPanel } from "@/components/design-system";

const POLICY_TEXT = "재입고: 코듀로이 볼캡 12/4";
const USER_TEXT = "볼캡 재입고 일정을 알고 싶어요";
const BOT_TEXT = "반가워요!";
const BOT_ANSWER_TEXT = "신상품 코듀로이 볼캡 입고 예정일 04/01입니다.";
const BOT_ANSWER_DETAIL = "예정일 2026-04-01 (D-26)";

const PHASES = ["policy_typing", "bot_greeting", "user_message", "bot_answer", "reset_pause"] as const;

export default function LoginDemoPage() {
  const [phaseIndex, setPhaseIndex] = useState(0);
  const [policyChars, setPolicyChars] = useState(0);
  const timerRef = useRef<number | null>(null);

  const phase = PHASES[phaseIndex] ?? "policy_typing";
  const policyValue = useMemo(() => POLICY_TEXT.slice(0, policyChars), [policyChars]);

  useEffect(() => {
    if (timerRef.current) window.clearTimeout(timerRef.current);

    if (phase === "policy_typing") {
      if (policyChars < POLICY_TEXT.length) {
        timerRef.current = window.setTimeout(() => setPolicyChars((v) => v + 1), 40);
        return;
      }
      timerRef.current = window.setTimeout(() => setPhaseIndex(1), 600);
      return;
    }

    if (phase === "bot_greeting") {
      timerRef.current = window.setTimeout(() => setPhaseIndex(2), 700);
      return;
    }

    if (phase === "user_message") {
      timerRef.current = window.setTimeout(() => setPhaseIndex(3), 900);
      return;
    }

    if (phase === "bot_answer") {
      timerRef.current = window.setTimeout(() => setPhaseIndex(4), 1200);
      return;
    }

    timerRef.current = window.setTimeout(() => {
      setPolicyChars(0);
      setPhaseIndex(0);
    }, 600);

    return () => {
      if (timerRef.current) window.clearTimeout(timerRef.current);
    };
  }, [phase, policyChars]);

  const messages = useMemo(() => {
    const items = [];
    if (phaseIndex >= 1) items.push({ id: "bot-greeting", role: "bot" as const, content: BOT_TEXT });
    if (phaseIndex >= 2) items.push({ id: "user-question", role: "user" as const, content: USER_TEXT });
    if (phaseIndex >= 3) items.push({ id: "bot-answer", role: "bot" as const, content: BOT_ANSWER_TEXT });
    return items;
  }, [phaseIndex]);

  return (
    <div className="min-h-screen w-full bg-gradient-to-br from-slate-50 via-white to-amber-50 p-6 text-slate-900">
      <div className="mx-auto flex w-full max-w-[420px] flex-col items-center gap-4">
        <div className="w-full text-center text-xs font-semibold tracking-[0.2em] text-slate-500">LOGIN DEMO</div>
        <div className="h-[420px] w-[320px] overflow-hidden rounded-[20px] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.15)]">
          <div className="flex h-full flex-col">
            <div className="border-b border-slate-200 bg-slate-900 px-4 py-3 text-white">
              <div className="text-[11px] uppercase tracking-[0.3em] text-amber-200">Widget Login</div>
              <div className="mt-1 text-base font-semibold">정책 기반 로그인</div>
            </div>

            <div className="flex-1 p-3">
              <div className="mb-3">
                <div className="mb-1 text-[11px] font-semibold text-slate-500">정책</div>
                <div className="text-xs text-slate-700">{policyValue || "정책을 입력합니다..."}</div>
              </div>

              <ConversationSetupPanel className="flex h-[250px] flex-col rounded-xl border-slate-200 bg-white">
                <div className="border-b border-slate-100 px-3 py-2 text-[11px] font-semibold text-slate-500">
                  대화
                </div>
                <div className="flex-1 overflow-hidden px-3 py-2">
                  <ConversationThread
                    messages={messages}
                    selectedMessageIds={[]}
                    selectionEnabled={false}
                    onToggleSelection={() => undefined}
                    bubbleBaseClassName="relative whitespace-pre-wrap break-words rounded-2xl px-4 py-2 text-sm transition"
                    userBubbleClassName="bg-slate-900 text-white"
                    botBubbleClassName="bg-slate-100 text-slate-700 border border-slate-200"
                    renderContent={(msg) =>
                      msg.id === "bot-answer" ? (
                        <div className="space-y-4">
                          <div className="whitespace-pre-wrap">{BOT_ANSWER_TEXT}</div>
                          <div className="space-y-1">
                            <div className="text-[11px] font-semibold text-slate-600">상세</div>
                            <div className="h-px bg-slate-200"></div>
                            <div className="whitespace-pre-wrap text-sm text-slate-700">{BOT_ANSWER_DETAIL}</div>
                          </div>
                        </div>
                      ) : (
                        <span>{msg.content}</span>
                      )
                    }
                    renderAfterBubble={(msg) =>
                      msg.id === "bot-answer" ? (
                        <>
                          <div className="mt-[5px]">
                            <div className="grid gap-2" style={{ gridTemplateColumns: "repeat(2, minmax(0px, 1fr))" }}>
                              <button
                                type="button"
                                className="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50"
                              >
                                재입고 알림 신청
                              </button>
                              <button
                                type="button"
                                className="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50"
                              >
                                대화 종료
                              </button>
                            </div>
                          </div>
                          <div className="mt-[5px] flex justify-end">
                            <button
                              type="button"
                              aria-label="선택 확인"
                              title="선택 확인"
                              disabled
                              className="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-slate-100 text-slate-400 disabled:cursor-not-allowed disabled:opacity-80"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                strokeWidth="2"
                                strokeLinecap="round"
                                strokeLinejoin="round"
                                className="lucide lucide-corner-down-right h-4 w-4"
                                aria-hidden="true"
                              >
                                <path d="m15 10 5 5-5 5"></path>
                                <path d="M4 4v7a4 4 0 0 0 4 4h12"></path>
                              </svg>
                            </button>
                          </div>
                        </>
                      ) : null
                    }
                  />
                </div>
                <div className="border-t border-slate-100 px-3 py-2 text-[11px] text-slate-400">
                  입력은 비활성화 상태입니다.
                </div>
              </ConversationSetupPanel>
            </div>

            <div className="border-t border-slate-200 bg-slate-50 px-3 py-2 text-[11px] text-slate-500">
              320x420 데모 · 루프 재생 중
            </div>
          </div>
        </div>
        <div className="text-[11px] text-slate-500">경로: /app/logindemo</div>
      </div>
    </div>
  );
}
