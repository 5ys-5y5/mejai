        isUserLoggedIn
      ),
      conversationMode: withVisibilityFlag(
        features.setup.conversationMode,
        features.visibility.setup.conversationMode,
        isAdminUser,
        isUserLoggedIn
      ),
      llmSelector: withVisibilityFlag(
        features.setup.llmSelector,
        features.visibility.setup.llmSelector,
