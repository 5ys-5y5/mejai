        isAdminUser,
        isUserLoggedIn
      ),
      widgetHeaderClose: withVisibilityFlag(
        features.interaction.widgetHeaderClose,
        features.visibility.interaction.widgetHeaderClose,
        isAdminUser,
        isUserLoggedIn
      ),
    },
      setup: {
        ...features.setup,
