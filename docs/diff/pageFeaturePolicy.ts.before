        versionSelector: override.visibility?.setup?.versionSelector ?? base.visibility.setup.versionSelector,
        sessionSelector: override.visibility?.setup?.sessionSelector ?? base.visibility.setup.sessionSelector,
        conversationMode: override.visibility?.setup?.conversationMode ?? base.visibility.setup.conversationMode,
