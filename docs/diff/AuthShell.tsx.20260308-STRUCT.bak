import Image from "next/image";
import React from "react";
import Link from "next/link";

interface AuthShellProps {
  title: string;
  subtitle?: string;
  children: React.ReactNode;
  footer?: React.ReactNode;
  showBrand?: boolean;
  showTitle?: boolean;
  showFooter?: boolean;
  contentMarginTop?: "none" | "default";
}

function BrandMark() {
  return (
    <Link href="/" className="flex items-center gap-2" aria-label="랜딩 페이지로 이동">
      <div className="relative h-9 w-9 overflow-hidden rounded-xl bg-slate-200">
        <Image src="/brand/logo.svg" alt="Mejai logo" fill sizes="36px" className="object-cover" priority />
      </div>
      <div className="leading-tight">
        <div className="font-semibold tracking-tight text-slate-900">Mejai</div>
      </div>
    </Link>
  );
}

export function AuthShell({
  title,
  subtitle,
  children,
  footer,
  showBrand = true,
  showTitle = true,
  showFooter = true,
  contentMarginTop = "default",
}: AuthShellProps) {
  const contentSpacingClass = contentMarginTop === "none" ? "mt-0" : "mt-6";
  return (
    <div className="min-h-screen bg-white text-slate-900">
      <div className="mx-auto flex min-h-screen w-full max-w-6xl flex-col items-center px-4 py-12">
        {showBrand ? (
          <div className="mb-10 flex items-center gap-2">
            <BrandMark />
          </div>
        ) : null}

        <div className="w-full max-w-md">
          {showTitle ? (
            <div className="text-center">
              <h1 className="text-2xl font-semibold tracking-tight text-slate-900">{title}</h1>
              {subtitle ? <p className="mt-2 text-sm text-slate-600">{subtitle}</p> : null}
            </div>
          ) : null}

          <div className={`${contentSpacingClass} rounded-2xl border border-slate-200 bg-white`}>
            <div className="p-5">
              {children}
              {footer && showFooter ? (
                <div className="mt-4 text-center text-sm text-slate-600">{footer}</div>
              ) : null}
            </div>
          </div>

          <div className="mt-10 text-center text-xs text-slate-500">© Mejai</div>
        </div>
      </div>
    </div>
  );
}
